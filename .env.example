# Salin file ini menjadi .env untuk pengembangan lokal, dan set nilai yang
# sama di Vercel → Project Settings → Environment Variables untuk produksi.

# --- Web Push (VAPID) ---
# Wajib untuk fitur push notification (jadwal sholat, dzikir, reminder keuangan)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alamat-email-anda@gmail.com

# --- Cron eksternal ---
# Dipakai untuk mengamankan /api/push/send-due dari akses sembarang orang.
# Cron eksternal (mis. cron-job.org) harus memanggil:
#   https://domain-anda.vercel.app/api/push/send-due?secret=NILAI_DI_BAWAH_INI
CRON_SECRET=

# --- Database (Upstash Redis via Vercel Marketplace) ---
# Otomatis terisi oleh Vercel saat Anda menghubungkan integrasi Upstash Redis.
# Untuk pengembangan lokal, KOSONGKAN saja — server.js otomatis memakai
# data/db.json & data/push-subs.json sebagai gantinya.
KV_REST_API_URL=
KV_REST_API_TOKEN=
